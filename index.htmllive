<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no, viewport-fit=cover">
    <title>ISKCON Admin | Master Studio</title>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@400;700;900&family=Barlow:wght@400;600;700&display=swap" rel="stylesheet">

    <style>
        :root {
            --saffron: #FF9933;
            --saffron-glow: rgba(255,153,51,0.35);
            --bg: #080808;
            --panel: #111111;
            --card: #181818;
            --danger: #FF3B3B;
            --danger-glow: rgba(255,59,59,0.3);
            --success: #00E676;
            --success-glow: rgba(0,230,118,0.25);
            --border: #242424;
            --text-dim: #666;
            --header-h: 52px;
            --deck-h: 185px;
        }

        * { box-sizing: border-box; -webkit-tap-highlight-color: transparent; outline: none; margin: 0; padding: 0; }

        html, body {
            height: 100%; width: 100%;
            background: var(--bg);
            color: white;
            font-family: 'Barlow', sans-serif;
            overflow: hidden;
            overscroll-behavior: none;
        }

        /* ═══ LAYOUT SHELL ═══ */
        #app {
            display: flex;
            flex-direction: column;
            height: 100dvh;
            width: 100%;
        }

        /* ═══ HEADER ═══ */
        .header {
            height: var(--header-h);
            min-height: var(--header-h);
            background: var(--panel);
            border-bottom: 1px solid var(--border);
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 0 14px;
            z-index: 10;
            flex-shrink: 0;
        }

        .brand {
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .brand-logo {
            font-family: 'Barlow Condensed', sans-serif;
            font-weight: 900;
            font-size: 1.15rem;
            color: var(--saffron);
            letter-spacing: 1.5px;
            text-transform: uppercase;
            line-height: 1;
        }

        .live-badge {
            display: none;
            align-items: center;
            gap: 5px;
            background: var(--danger);
            padding: 3px 9px;
            border-radius: 4px;
            font-family: 'Barlow Condensed', sans-serif;
            font-weight: 700;
            font-size: 0.75rem;
            letter-spacing: 1px;
            animation: badgePulse 1.4s ease infinite;
        }

        body.is-live .live-badge { display: flex; }

        @keyframes badgePulse {
            0%, 100% { opacity: 1; }
            50% { opacity: 0.7; }
        }

        .live-dot {
            width: 6px; height: 6px;
            background: white;
            border-radius: 50%;
            animation: dotBlink 1s ease infinite;
        }

        @keyframes dotBlink {
            0%, 100% { opacity: 1; }
            50% { opacity: 0.3; }
        }

        .header-right {
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .viewer-pill {
            display: flex;
            align-items: center;
            gap: 6px;
            background: var(--card);
            border: 1px solid var(--border);
            padding: 5px 12px;
            border-radius: 20px;
            font-family: 'Barlow Condensed', sans-serif;
            font-size: 1rem;
            font-weight: 700;
            letter-spacing: 0.5px;
        }

        .viewer-pill i { color: var(--text-dim); font-size: 0.75rem; }
        .viewer-pill span { color: white; }

        .reactions-pill {
            display: flex;
            align-items: center;
            gap: 5px;
            background: var(--card);
            border: 1px solid var(--border);
            padding: 5px 11px;
            border-radius: 20px;
            font-family: 'Barlow Condensed', sans-serif;
            font-size: 0.95rem;
            font-weight: 700;
            color: #aaa;
        }

        .reactions-pill .count { color: white; }

        .icon-btn {
            width: 36px; height: 36px;
            background: var(--card);
            border: 1px solid var(--border);
            border-radius: 50%;
            display: grid;
            place-items: center;
            cursor: pointer;
            font-size: 0.85rem;
            color: #aaa;
            transition: border-color 0.2s, color 0.2s;
        }

        .icon-btn:active { transform: scale(0.92); }

        /* ═══ STAGE ═══ */
        .stage {
            flex: 1;
            background: #000;
            position: relative;
            overflow: hidden;
            min-height: 0;
        }

        #local-player {
            width: 100%; height: 100%;
            object-fit: cover;
        }

        #yt-admin-player {
            position: absolute;
            inset: 0;
            width: 100%;
            height: 100%;
            z-index: 5;
            display: none;
            pointer-events: auto; /* Admin must be able to control the player */
        }

        /* Offline placeholder */
        .stage-placeholder {
            position: absolute;
            inset: 0;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            gap: 12px;
            background: #0a0a0a;
        }

        .placeholder-icon {
            width: 70px; height: 70px;
            border: 2px solid var(--border);
            border-radius: 50%;
            display: grid;
            place-items: center;
            font-size: 1.8rem;
            color: #333;
        }

        .placeholder-text { color: #333; font-size: 0.85rem; font-weight: 600; }

        /* Mute overlay */
        .mute-tag {
            position: absolute;
            top: 12px; left: 12px;
            background: rgba(0,0,0,0.75);
            color: var(--danger);
            padding: 4px 10px;
            border-radius: 6px;
            border: 1px solid var(--danger);
            font-size: 0.72rem;
            font-weight: 700;
            display: none;
            align-items: center;
            gap: 6px;
            backdrop-filter: blur(8px);
            z-index: 10;
        }

        body.is-muted .mute-tag { display: flex; }

        /* Duration Timer */
        .duration-tag {
            position: absolute;
            top: 12px; right: 12px;
            background: rgba(0,0,0,0.7);
            padding: 4px 10px;
            border-radius: 6px;
            font-family: 'Barlow Condensed', sans-serif;
            font-size: 0.95rem;
            font-weight: 700;
            letter-spacing: 1px;
            display: none;
            backdrop-filter: blur(8px);
            z-index: 10;
        }

        body.is-live .duration-tag { display: block; }

        /* ═══ REACTION FLOATING AREA ═══ */
        #reaction-stage {
            position: absolute;
            bottom: 0; right: 10px;
            width: 60px;
            height: 80%;
            pointer-events: none;
            overflow: hidden;
            z-index: 10;
        }

        .float-reaction {
            position: absolute;
            bottom: 0;
            right: 5px;
            font-size: 1.5rem;
            opacity: 0;
            animation: floatUp 3s ease-out forwards;
            pointer-events: none;
            filter: drop-shadow(0 2px 6px rgba(0,0,0,0.5));
        }

        @keyframes floatUp {
            0%   { opacity: 1; transform: translateY(0) scale(0.7) rotate(-5deg); }
            30%  { opacity: 1; transform: translateY(-60px) scale(1.2) rotate(5deg); }
            70%  { opacity: 0.7; transform: translateY(-130px) scale(1) rotate(-3deg); }
            100% { opacity: 0; transform: translateY(-210px) scale(0.8) rotate(8deg); }
        }

        /* ═══ DECK (Bottom Controls) ═══ */
        .deck {
            background: var(--panel);
            border-top: 1px solid var(--border);
            padding: 12px 14px;
            padding-bottom: max(12px, env(safe-area-inset-bottom));
            flex-shrink: 0;
            display: flex;
            flex-direction: column;
            gap: 10px;
        }

        /* Server row */
        .server-wrap {
            display: flex;
            gap: 8px;
            align-items: center;
            background: #0a0a0a;
            border: 1px solid var(--border);
            border-radius: 10px;
            padding: 0 4px 0 10px;
            height: 42px;
        }

        .server-dot {
            width: 8px; height: 8px;
            background: var(--text-dim);
            border-radius: 50%;
            flex-shrink: 0;
            transition: background 0.3s, box-shadow 0.3s;
        }

        .server-dot.on {
            background: var(--success);
            box-shadow: 0 0 8px var(--success);
            animation: dotBlink 1.2s ease infinite;
        }

        .server-label {
            font-size: 0.75rem;
            font-weight: 700;
            color: var(--text-dim);
            text-transform: uppercase;
            letter-spacing: 0.5px;
            flex-shrink: 0;
        }

        #serverSelect {
            flex: 1;
            background: none;
            border: none;
            color: white;
            font-family: 'Barlow', sans-serif;
            font-size: 0.9rem;
            font-weight: 600;
            text-align: right;
            padding: 0 8px;
            -webkit-appearance: none;
        }

        /* Main button row */
        .btn-row {
            display: grid;
            grid-template-columns: 52px 1fr 52px;
            gap: 10px;
            height: 60px;
        }

        .ctrl-btn {
            border: none;
            border-radius: 12px;
            cursor: pointer;
            transition: transform 0.15s, background 0.2s;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.1rem;
        }

        .ctrl-btn:active { transform: scale(0.93); }

        .ctrl-sq {
            background: var(--card);
            color: #ccc;
            border: 1px solid var(--border);
        }

        .ctrl-sq.danger {
            background: rgba(255,59,59,0.12);
            border-color: rgba(255,59,59,0.5);
            color: var(--danger);
        }

        .ctrl-main {
            background: var(--saffron);
            color: #000;
            font-family: 'Barlow Condensed', sans-serif;
            font-weight: 900;
            font-size: 1.5rem;
            letter-spacing: 2px;
            box-shadow: 0 4px 20px var(--saffron-glow);
            border-radius: 14px;
        }

        .ctrl-main.stop {
            background: var(--danger);
            box-shadow: 0 4px 20px var(--danger-glow);
            color: white;
        }

        /* Reaction Row */
        .reaction-row {
            display: flex;
            align-items: center;
            justify-content: space-around;
            padding: 4px 0 2px;
        }

        .react-btn {
            background: none;
            border: none;
            font-size: 1.4rem;
            cursor: pointer;
            padding: 4px 10px;
            border-radius: 8px;
            transition: transform 0.15s;
            line-height: 1;
        }

        .react-btn:active { transform: scale(1.4); }

        .react-label {
            font-size: 0.68rem;
            color: var(--text-dim);
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            align-self: center;
        }

        /* ═══ MODAL ═══ */
        #settings-modal {
            position: fixed;
            inset: 0;
            background: rgba(0,0,0,0.92);
            z-index: 2000;
            display: none;
            justify-content: center;
            align-items: center;
            backdrop-filter: blur(6px);
        }

        #settings-modal.open { display: flex; }

        .s-card {
            background: var(--card);
            width: 92%;
            max-width: 400px;
            padding: 22px;
            border-radius: 18px;
            border: 1px solid var(--border);
            max-height: 85dvh;
            overflow-y: auto;
        }

        .s-title {
            font-family: 'Barlow Condensed', sans-serif;
            font-size: 1.3rem;
            font-weight: 900;
            color: var(--saffron);
            letter-spacing: 1px;
            margin-bottom: 16px;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .s-label {
            font-size: 0.72rem;
            font-weight: 700;
            color: var(--text-dim);
            text-transform: uppercase;
            letter-spacing: 0.5px;
            margin-bottom: 5px;
        }

        .s-inp {
            width: 100%;
            background: #0d0d0d;
            border: 1px solid var(--border);
            padding: 11px 14px;
            color: white;
            border-radius: 8px;
            margin-bottom: 8px;
            font-family: 'Barlow', sans-serif;
            font-size: 0.9rem;
            transition: border-color 0.2s;
        }

        .s-inp:focus { border-color: var(--saffron); }
        .s-inp:disabled { background: #050505; color: #555; border-color: #111; cursor: not-allowed; }

        .s-save {
            width: 100%;
            height: 48px;
            background: var(--saffron);
            border: none;
            border-radius: 10px;
            color: #000;
            font-family: 'Barlow Condensed', sans-serif;
            font-weight: 900;
            font-size: 1.1rem;
            letter-spacing: 1.5px;
            cursor: pointer;
            margin-top: 6px;
        }

        .s-save:active { transform: scale(0.97); }
        
        .s-clear {
            width: 100%;
            height: 40px;
            background: #2a0000;
            border: 1px solid var(--danger);
            border-radius: 10px;
            color: var(--danger);
            font-family: 'Barlow', sans-serif;
            font-weight: 700;
            font-size: 0.9rem;
            cursor: pointer;
            margin-top: 8px;
        }
        .s-clear:disabled { opacity: 0.5; cursor: not-allowed; }

        /* ═══ TOAST ═══ */
        #toast-container {
            position: fixed;
            bottom: calc(var(--deck-h) + 10px);
            left: 50%;
            transform: translateX(-50%);
            z-index: 9999;
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 6px;
            pointer-events: none;
        }

        .toast {
            background: #1c1c1c;
            padding: 9px 18px;
            border-radius: 40px;
            box-shadow: 0 4px 20px black;
            animation: toastIn 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
            display: flex;
            gap: 8px;
            align-items: center;
            white-space: nowrap;
            font-size: 0.85rem;
            font-weight: 600;
        }

        @keyframes toastIn {
            from { transform: translateY(12px); opacity: 0; }
            to   { transform: translateY(0); opacity: 1; }
        }

        /* ═══ LANDSCAPE MODE ═══ */
        @media (orientation: landscape) {
            :root { --header-h: 44px; }

            #app {
                flex-direction: row;
            }

            .header {
                display: none; /* hidden in landscape — controls show in sidebar */
            }

            .stage {
                flex: 1;
                height: 100dvh;
            }

            .deck {
                width: 220px;
                min-width: 220px;
                height: 100dvh;
                border-top: none;
                border-left: 1px solid var(--border);
                flex-direction: column;
                justify-content: space-between;
                padding: 16px 12px;
                padding-bottom: max(16px, env(safe-area-inset-bottom));
                overflow-y: auto;
            }

            .landscape-brand {
                display: flex !important;
                align-items: center;
                gap: 8px;
                margin-bottom: 4px;
            }

            .ls-stats {
                display: flex !important;
                flex-direction: column;
                gap: 8px;
            }

            .btn-row {
                grid-template-columns: 1fr;
                grid-template-rows: 44px 56px 44px;
                height: auto;
            }

            .server-wrap {
                height: 38px;
                font-size: 0.8rem;
            }

            .reaction-row {
                flex-wrap: wrap;
                gap: 6px;
                justify-content: center;
            }

            .react-btn { font-size: 1.2rem; padding: 3px 8px; }

            .ctrl-main { font-size: 1.2rem; }
        }

        /* Portrait only elements */
        .landscape-brand, .ls-stats { display: none; }

        /* ═══ SMALL SCREEN TWEAKS ═══ */
        @media (max-height: 600px) and (orientation: portrait) {
            .reaction-row { display: none; }
            :root { --deck-h: 145px; }
        }

        @media (max-width: 360px) {
            .viewer-pill, .reactions-pill { padding: 4px 8px; font-size: 0.85rem; }
            .icon-btn { width: 32px; height: 32px; font-size: 0.78rem; }
            .react-btn { font-size: 1.2rem; }
        }
    </style>
</head>
<body>

<div id="app">
    <div id="toast-container"></div>

    <!-- HEADER -->
    <div class="header">
        <div class="brand">
            <div class="brand-logo">☸ ISKCON STUDIO</div>
            <div class="live-badge"><div class="live-dot"></div> LIVE</div>
        </div>
        <div class="header-right">
            <div class="viewer-pill">
                <i class="fas fa-eye"></i>
                <span id="viewCount">0</span>
            </div>
            <div class="reactions-pill">
                ❤️ <span class="count" id="totalReactions">0</span>
            </div>
            <div class="icon-btn" onclick="openSettings()"><i class="fas fa-sliders-h"></i></div>
        </div>
    </div>

    <!-- VIDEO STAGE -->
    <div class="stage">
        <!-- Local Camera / WebRTC Video -->
        <div id="local-player"></div>
        
        <!-- Admin YouTube Sync Player -->
        <div id="yt-admin-player"></div>

        <div class="stage-placeholder" id="stagePlaceholder">
            <div class="placeholder-icon">
                <i class="fas fa-video"></i>
            </div>
            <div class="placeholder-text">Camera loading...</div>
        </div>

        <div class="mute-tag"><i class="fas fa-microphone-slash"></i> MIC MUTED</div>
        <div class="duration-tag" id="durationTag">00:00</div>
        <div id="reaction-stage"></div>
    </div>

    <!-- DECK / CONTROLS -->
    <div class="deck">

        <!-- Landscape brand (only shows in landscape) -->
        <div>
            <div class="landscape-brand">
                <span style="font-family:'Barlow Condensed',sans-serif; font-weight:900; font-size:1rem; color:var(--saffron); letter-spacing:1px;">☸ ISKCON STUDIO</span>
                <div class="live-badge" style="font-size:0.7rem;"><div class="live-dot"></div> LIVE</div>
            </div>

            <!-- Stats row for landscape -->
            <div class="ls-stats">
                <div class="viewer-pill" style="justify-content:center;">
                    <i class="fas fa-eye"></i> <span id="viewCount2">0</span> watching
                </div>
                <div class="reactions-pill" style="justify-content:center;">
                    ❤️ <span class="count" id="totalReactions2">0</span> reactions
                </div>
            </div>
        </div>

        <!-- Server Select -->
        <div>
            <div class="server-wrap">
                <div class="server-dot" id="serverDot"></div>
                <span class="server-label">SRV</span>
                <select id="serverSelect" onchange="switchServerContext()">
                    <option value="0">Server 01 — Main</option>
                    <option value="1">Server 02</option>
                    <option value="2">Server 03</option>
                    <option value="3">Server 04</option>
                    <option value="4">Server 05</option>
                </select>
            </div>
        </div>

        <!-- Main Controls -->
        <div class="btn-row">
            <button id="micBtn" class="ctrl-btn ctrl-sq" onclick="toggleMic()">
                <i class="fas fa-microphone"></i>
            </button>
            <button id="liveBtn" class="ctrl-btn ctrl-main" onclick="toggleLive()">GO LIVE</button>
            <button id="camBtn" class="ctrl-btn ctrl-sq" onclick="switchCamera()">
                <i class="fas fa-sync-alt"></i>
            </button>
        </div>

        <!-- Reaction Row -->
        <div class="reaction-row">
            <span class="react-label">Bhavo ko dekhein →</span>
            <button class="react-btn" onclick="sendReaction('❤️')">❤️</button>
            <button class="react-btn" onclick="sendReaction('🙏')">🙏</button>
            <button class="react-btn" onclick="sendReaction('🌸')">🌸</button>
            <button class="react-btn" onclick="sendReaction('🔔')">🔔</button>
            <button class="react-btn" onclick="sendReaction('🌿')">🌿</button>
        </div>

    </div>
</div>

<!-- SETTINGS MODAL -->
<div id="settings-modal">
    <div class="s-card">
        <div class="s-title"><i class="fas fa-cog"></i> Broadcast Setup</div>
        
        <div id="idInputs">
            <!-- Dynamically populated settings -->
        </div>
        
        <button class="s-save" onclick="saveConfig()">SAVE & CLOSE</button>
        <button onclick="closeSettings()" style="width:100%; margin-top:8px; background:none; border:1px solid var(--border); color:#666; padding:10px; border-radius:8px; cursor:pointer; font-size:0.85rem;">Cancel</button>
    </div>
</div>

<!-- SCRIPTS -->
<script src="https://download.agora.io/sdk/release/AgoraRTC_N-4.18.2.js"></script>
<script src="https://www.youtube.com/iframe_api"></script>
<script type="module">
    import { initializeApp } from "https://www.gstatic.com/firebasejs/9.6.1/firebase-app.js";
    import { getDatabase, ref, set, onValue, update, onDisconnect, increment, serverTimestamp } from "https://www.gstatic.com/firebasejs/9.6.1/firebase-database.js";

    // ─── FIREBASE CONFIG ───
    const FB_CFG = {
        apiKey: "AIzaSyBfbNzASqzPt4kMP-LlpJasIras7ifTch4",
        authDomain: "iskcon-hadapsar.firebaseapp.com",
        databaseURL: "https://iskcon-hadapsar-default-rtdb.firebaseio.com",
        projectId: "iskcon-hadapsar",
        appId: "1:231589086724:web:64d8a5d7a136b39db39751"
    };

    const app = initializeApp(FB_CFG);
    const db = getDatabase(app);

    // ─── GLOBAL STATE ───
    const S = {
        client: AgoraRTC.createClient({ mode: "live", codec: "h264" }),
        localAudio: null,
        localVideo: null,
        isLive: false,
        isMuted: false,
        serverIndex: 0,
        cameras:[],
        camIdx: 0,
        agoraIds:[],
        durationStart: null,
        durationTimer: null,
        totalReactions: 0,
        mode: 'agora', // 'agora' ya 'youtube'
        ytVideoId: null,
        ytPlayer: null,
        ytReady: false,
        ytSyncInterval: null
    };

    AgoraRTC.setLogLevel(3);

    // ─── INIT YOUTUBE API ───
    window.onYouTubeIframeAPIReady = function() {
        S.ytPlayer = new YT.Player('yt-admin-player', {
            height: '100%', width: '100%',
            videoId: '',
            playerVars: { controls: 1, rel: 0, autoplay: 1 },
            events: {
                onReady: () => { S.ytReady = true; },
                onStateChange: (e) => {
                    // Jab admin video ko play/pause/seek karega, Real-time sync Firebase pe push hoga
                    if(S.isLive && S.mode === 'youtube') pushYtSync();
                }
            }
        });
    };

    function pushYtSync() {
        if(!S.ytReady || !S.ytPlayer) return;
        update(ref(db, 'live_status'), {
            ytState: S.ytPlayer.getPlayerState() || 1,
            ytTime: S.ytPlayer.getCurrentTime() || 0,
            timestamp: Date.now()
        });
    }

    // ─── INIT AGORA & FIREBASE ───
    async function init() {
        try {[S.localAudio, S.localVideo] = await AgoraRTC.createMicrophoneAndCameraTracks(
                { encoderConfig: "music_standard" },
                { encoderConfig: { width: 1280, height: 720, frameRate: 24, bitrateMin: 400, bitrateMax: 1200 } }
            );

            S.localVideo.play("local-player");
            document.getElementById('stagePlaceholder').style.display = 'none';

            const devices = await AgoraRTC.getDevices();
            S.cameras = devices.filter(d => d.kind === "videoinput");

        } catch(e) {
            showToast("Camera/Mic Permission Denied!", 'err');
            document.querySelector('.placeholder-text').textContent = 'Permission Denied';
        }

        onValue(ref(db, 'viewers'), snap => {
            const count = snap.size || (snap.val() ? Object.keys(snap.val()).length : 0);
            setViewCount(count);
        });

        onValue(ref(db, 'reactions/total'), snap => {
            S.totalReactions = snap.val() || 0;
            document.getElementById('totalReactions').textContent = S.totalReactions;
            document.getElementById('totalReactions2').textContent = S.totalReactions;
        });

        onValue(ref(db, 'reactions/latest'), snap => {
            const data = snap.val();
            if(data && data.emoji) spawnReaction(data.emoji);
        });

        onValue(ref(db, 'config/agora_ids'), snap => {
            S.agoraIds = snap.val() ||[];
        });
    }

    init();

    // ─── LIVE TOGGLE ───
    window.toggleLive = async () => {
        if(S.isLive) {
            if(!confirm("Darshan Band Karna Chahte Ho?")) return;
            try {
                if(S.mode === 'agora') {
                    await S.client.leave();
                } else {
                    clearInterval(S.ytSyncInterval);
                }
                
                setLiveUI(false);
                stopDuration();
                await update(ref(db, 'live_status'), { isLive: false, muted: false });
                showToast("Broadcast Band Ho Gaya 🙏");
            } catch(e) { showToast("Error: " + (e.message||e.code), 'err'); }
        } else {
            const sIdx = document.getElementById('serverSelect').value;
            const appId = S.agoraIds[sIdx];
            
            if(S.mode === 'agora' && !appId) return showToast("Settings mein App ID daalo!", 'err');

            const btn = document.getElementById('liveBtn');
            btn.textContent = "Jod Raha...";
            btn.disabled = true;

            try {
                if(S.mode === 'agora') {
                    await S.client.setClientRole("host");
                    await S.client.join(appId, "iskcon_live", null, null);
                    await S.client.publish([S.localVideo, S.localAudio]);
                    
                    // Slow Network Optimization
                    S.client.enableDualStream().catch(()=>{});

                    await set(ref(db, 'live_status'), {
                        isLive: true,
                        mode: 'agora',
                        serverIndex: S.serverIndex,
                        appId: appId,
                        muted: S.isMuted,
                        startedAt: serverTimestamp ? serverTimestamp() : Date.now()
                    });
                } else {
                    // YouTube Broadcast Mode
                    pushYtSync();
                    S.ytSyncInterval = setInterval(pushYtSync, 2000); // Har 2 sec me exactly sync karta rahega
                    
                    await set(ref(db, 'live_status'), {
                        isLive: true,
                        mode: 'youtube',
                        ytVideoId: S.ytVideoId,
                        ytState: S.ytPlayer.getPlayerState() || 1,
                        ytTime: S.ytPlayer.getCurrentTime() || 0,
                        timestamp: Date.now(),
                        startedAt: serverTimestamp ? serverTimestamp() : Date.now()
                    });
                }

                setLiveUI(true);
                startDuration();
                S.serverIndex = parseInt(sIdx);

                onDisconnect(ref(db, 'live_status')).set({ isLive: false });
                showToast("🔴 LIVE Ho Gaye! Hare Krishna 🙏");
            } catch(e) {
                showToast("Connect Error: " + (e.message||e.code||e), 'err');
                setLiveUI(false);
                btn.disabled = false;
            }
        }
    };

    // ─── INSTANT REAL-TIME SERVER SWITCH (ZERO DELAY) ───
    window.switchServerContext = async () => {
        const sIdx = document.getElementById('serverSelect').value;
        S.serverIndex = parseInt(sIdx);
        
        if(!S.isLive || S.mode !== 'agora') return; // Agar live nahi hai, ya youtube chal rha hai to sirf index update hoga
        
        const newAppId = S.agoraIds[sIdx];
        if(!newAppId) return showToast("Naya Server ID missing!", "err");
        
        showToast("Swapping Server instantly... ⚡");
        try {
            await S.client.leave(); // instantly disconnect old
            await S.client.join(newAppId, "iskcon_live", null, null); // instantly join new
            await S.client.publish([S.localVideo, S.localAudio]);
            
            // Firebase pe update karte hi sabhi Users auto switch ho jayenge!
            await update(ref(db, 'live_status'), {
                serverIndex: S.serverIndex,
                appId: newAppId
            });
            showToast("Server Switched Real-time! ✅");
        } catch(e) {
            showToast("Switch Failed: " + e.message, "err");
        }
    };

    // ─── MIC ───
    window.toggleMic = () => {
        if(!S.localAudio) return;
        S.isMuted = !S.isMuted;
        S.localAudio.setEnabled(!S.isMuted);
        if(S.isLive && S.mode === 'agora') update(ref(db, 'live_status'), { muted: S.isMuted });

        const btn = document.getElementById('micBtn');
        if(S.isMuted) {
            btn.classList.add('danger');
            btn.innerHTML = '<i class="fas fa-microphone-slash"></i>';
            document.body.classList.add('is-muted');
            showToast("🔇 Mic Mute Ho Gaya", 'warn');
        } else {
            btn.classList.remove('danger');
            btn.innerHTML = '<i class="fas fa-microphone"></i>';
            document.body.classList.remove('is-muted');
            showToast("🎙️ Mic Chalu Ho Gaya");
        }
    };

    // ─── CAMERA ───
    window.switchCamera = async () => {
        if(S.cameras.length < 2) return showToast("Sirf 1 Camera Mila", 'warn');
        const btn = document.getElementById('camBtn');
        btn.disabled = true;
        S.camIdx = (S.camIdx + 1) % S.cameras.length;
        try {
            await S.localVideo.setDevice(S.cameras[S.camIdx].deviceId);
            showToast("Camera Switch Ho Gaya 📷");
        } catch(e) {
            showToast("Switch Failed: " + e.message, 'err');
        }
        btn.disabled = false;
    };

    // ─── REACTIONS ───
    window.sendReaction = async (emoji) => {
        spawnReaction(emoji);
        try {
            await update(ref(db, 'reactions'), {
                total: S.totalReactions + 1,
                latest: { emoji, ts: Date.now() }
            });
        } catch(e) { }
    };

    function spawnReaction(emoji) {
        const stage = document.getElementById('reaction-stage');
        const el = document.createElement('div');
        el.className = 'float-reaction';
        el.textContent = emoji;
        el.style.right = (Math.random() * 40) + 'px';
        stage.appendChild(el);
        setTimeout(() => el.remove(), 3200);
    }

    // ─── UI HELPERS ───
    function setLiveUI(live) {
        S.isLive = live;
        const btn = document.getElementById('liveBtn');
        const dot = document.getElementById('serverDot');
        document.body.classList.toggle('is-live', live);
        btn.disabled = false;

        if(live) {
            btn.classList.add('stop');
            btn.textContent = "STOP LIVE";
            dot.classList.add('on');
        } else {
            btn.classList.remove('stop');
            btn.textContent = "GO LIVE";
            dot.classList.remove('on');
        }
    }

    function setViewCount(n) {
        document.getElementById('viewCount').textContent = n;
        document.getElementById('viewCount2').textContent = n;
    }

    function startDuration() {
        S.durationStart = Date.now();
        S.durationTimer = setInterval(() => {
            const sec = Math.floor((Date.now() - S.durationStart) / 1000);
            const h = Math.floor(sec / 3600);
            const m = Math.floor((sec % 3600) / 60);
            const s = sec % 60;
            const str = h > 0 ? `${pad(h)}:${pad(m)}:${pad(s)}` : `${pad(m)}:${pad(s)}`;
            document.getElementById('durationTag').textContent = str;
        }, 1000);
    }

    function stopDuration() {
        clearInterval(S.durationTimer);
        document.getElementById('durationTag').textContent = '00:00';
    }

    function pad(n) { return String(n).padStart(2, '0'); }

    // ─── SETTINGS ───
    window.openSettings = () => {
        const div = document.getElementById('idInputs');
        div.innerHTML = '';
        
        // Disable YT inputs if already live "Live me link edit mana hai"
        const ytDisabled = S.isLive ? 'disabled' : '';
        
        div.innerHTML += `
            <div style="font-size:.7rem;font-weight:700;color:#FF3B3B;text-transform:uppercase;letter-spacing:.5px;margin-bottom:6px;">
                <i class="fab fa-youtube"></i>&nbsp; YouTube Live Video ID
            </div>
            <input class="s-inp" id="yt_video_id" placeholder="YouTube URL paste karo" value="${S.ytVideoId || ''}" ${ytDisabled}>
            <button class="s-clear" onclick="window.clearYtLink()" ${ytDisabled}>Clear YT Video (Use Camera)</button>
            <div style="font-size:.68rem;color:#555;margin-top:6px;margin-bottom:14px;">
                Link disable ho jata hai jab stream Live hoti hai.
            </div>
            
            <div style="border-top:1px solid #222;padding-top:12px;font-size:.7rem;font-weight:700;color:var(--saffron);text-transform:uppercase;letter-spacing:.5px;margin-bottom:6px;">
                Agora Server IDs
            </div>
        `;
        for(let i = 0; i < 5; i++) {
            div.innerHTML += `
                <div class="s-label">Server ${i+1} App ID</div>
                <input class="s-inp" id="id_${i}" placeholder="Enter Agora App ID" value="${S.agoraIds[i]||''}">
            `;
        }
        document.getElementById('settings-modal').classList.add('open');
    };

    window.closeSettings = () => {
        document.getElementById('settings-modal').classList.remove('open');
    };

    window.clearYtLink = () => {
        if(S.isLive) return; // Prevent clear while live
        document.getElementById('yt_video_id').value = '';
    };

    window.saveConfig = async () => {
        const arr =[];
        for(let i = 0; i < 5; i++) arr.push(document.getElementById(`id_${i}`).value.trim());
        await set(ref(db, 'config/agora_ids'), arr);
        
        // Handle YT Sync setup
        if(!S.isLive) {
            let ytRaw = (document.getElementById('yt_video_id')?.value || '').trim();
            if(ytRaw) {
                const m = ytRaw.match(/(?:v=|youtu\.be\/)([a-zA-Z0-9_-]{11})/);
                if(m) ytRaw = m[1];
                ytRaw = ytRaw.slice(0, 11);
                
                S.mode = 'youtube';
                S.ytVideoId = ytRaw;
                document.getElementById('yt-admin-player').style.display = 'block'; // Show YT
                if(S.ytReady && S.ytPlayer) S.ytPlayer.loadVideoById(ytRaw);
            } else {
                S.mode = 'agora';
                S.ytVideoId = null;
                document.getElementById('yt-admin-player').style.display = 'none'; // Back to camera
                if(S.ytReady && S.ytPlayer) S.ytPlayer.stopVideo();
            }
        }
        
        closeSettings();
        showToast("Settings Save Ho Gayi ✅");
    };

    document.getElementById('settings-modal').addEventListener('click', function(e) {
        if(e.target === this) closeSettings();
    });

    // ─── TOAST ───
    function showToast(msg, type = 'ok') {
        const c = document.getElementById('toast-container');
        const el = document.createElement('div');
        el.className = 'toast';
        const colorMap = { ok: '#00E676', err: '#FF3B3B', warn: '#FF9933' };
        const iconMap = { ok: 'fa-check-circle', err: 'fa-exclamation-circle', warn: 'fa-exclamation-triangle' };
        el.style.borderLeft = `3px solid ${colorMap[type]||colorMap.ok}`;
        el.innerHTML = `<i class="fas ${iconMap[type]||iconMap.ok}" style="color:${colorMap[type]||colorMap.ok};"></i> ${msg}`;
        c.appendChild(el);
        setTimeout(() => el.remove(), 3000);
    }
    window.showToast = showToast;

    window.onbeforeunload = () => {
        if(S.isLive) return "Live stream chal rahi hai!";
    };
</script>

</body>
</html>
